# Copy to .env for local shell scripts.
WANDB_PROJECT=rl-translational-dynamics
WANDB_MODE=offline
TRACK=false

# Common local run knobs.
ENVS="Hopper-v4 Walker2d-v4"
SEEDS="0 1 2"
TOTAL_TIMESTEPS=100000
EVAL_INTERVAL=5000
NUM_EVAL_EPISODES=5

# Modal settings.
WANDB_MODAL_SECRET=wandb-api-key
MODAL_RESULTS_VOLUME=rl-translational-dynamics-results
MODAL_GPU=L4

